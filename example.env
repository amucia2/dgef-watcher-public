# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore.

# ── DGEF account ──────────────────────────────────────────────
DGEF_EMAIL=
DGEF_PASSWORD=

# ── Email notification ────────────────────────────────────────
# The address that sends the alert (must match SMTP_USER for Gmail)
NOTIFY_EMAIL_FROM=
# The address that receives the alert (can be same or different)
NOTIFY_EMAIL_TO=   # or same gmail, or any email

# ── SMTP (Gmail example) ──────────────────────────────────────
# Use a Gmail App Password, NOT your regular Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2FA to be enabled on your Google account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=   # 16-char App Password

# ── Optional tuning ───────────────────────────────────────────
STATE_FILE=state.json
SCREENSHOT_DIR=screenshots
PAGE_LOAD_TIMEOUT=30
WAIT_AFTER_LOGIN=5
NO_CHANGE_ALERT_DAYS=15
